# Point to the Image Processing Service (FastAPI) so /inventory/detect uses real analysis
# instead of the in-app Azure client or hardcoded fallback.
IMAGE_PROCESSING_SERVICE_URL=http://localhost:5003

# Default false: failed detection returns an error instead of fake Milk/Eggs/Bread/Butter.
# Set true only for offline demos.
ALLOW_DETECTION_FALLBACK=false

# Only used when IMAGE_PROCESSING_SERVICE_URL is unset (direct Azure in InventoryService)
AZURE_SUBSCRIPTION_KEY=
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

DATABASE_URL=sqlite:///./inventory.db
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
