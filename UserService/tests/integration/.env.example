# Environment variables for integration testing
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/userdb_test
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=userdb_test

# JWT Configuration
JWT_SECRET=test-secret-key
JWT_EXP_MIN=60

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Test Configuration
TEST_MODE=true